# Copiez ce fichier vers .env puis remplacez toutes les valeurs d'exemple.
# Générez les trois premières avec : openssl rand -hex 32
POSTGRES_PASSWORD=REMPLACEZ_MOI_POSTGRES
SECRET_KEY=REMPLACEZ_MOI_CLE_JWT_32_CARACTERES_MINIMUM
MASTER_ENCRYPTION_KEY=REMPLACEZ_MOI_CLE_CHIFFREMENT_32_CARACTERES_MINIMUM
ADMIN_USERNAME=admin
# 12 caractères minimum : majuscule, minuscule, chiffre et caractère spécial.
ADMIN_PASSWORD=REMPLACEZ_MOI_ADMIN
HTTP_PORT=8080
# Utilisez 127.0.0.1 lorsque Caddy est installé sur le même serveur.
HTTP_BIND=0.0.0.0

# Paramètres applicatifs facultatifs.
APP_NAME=NetScope
ACCESS_TOKEN_MINUTES=120
# Origines autorisées, séparées par des virgules et sans chemin final.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
# Nombre maximal d'hôtes acceptés dans une cible de scan.
MAX_SCAN_HOSTS=4096

# Sauvegardes PostgreSQL automatiques.
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14

# Supervision facultative (profil Docker "monitoring").
MONITORING_BIND=127.0.0.1
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REMPLACEZ_MOI_GRAFANA
METRICS_RETENTION=15d
NTFY_PORT=8081
NTFY_BASE_URL=http://localhost:8081

# Envoi facultatif des rapports. Laissez SMTP_HOST vide pour désactiver.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=15
# Adresses autorisées dans le champ expéditeur, séparées par des virgules.
SMTP_SENDERS=

# Identifiant SNMP par défaut facultatif. Préférez les identifiants chiffrés créés dans l'API.
# Valeurs possibles : 3, 2c, ou vide pour exiger un identifiant à chaque scan.
SNMP_DEFAULT_VERSION=
SNMPV3_USERNAME=
SNMPV3_SECURITY_LEVEL=authPriv
SNMPV3_AUTH_PROTOCOL=SHA
SNMPV3_AUTH_PASSWORD=
SNMPV3_PRIVACY_PROTOCOL=AES
SNMPV3_PRIVACY_PASSWORD=
# SNMPv2c est compatible mais non chiffré. À utiliser seulement sur un réseau maîtrisé.
SNMPV2_COMMUNITY=
